{
  "manifest_version": 3,
  "name": "ADEQ Toolbar",
  "version": "3.1.0",
  "key": "",
  "description": "Automated B2B prospecting tool for ADEQ Media — analyze websites, qualify leads, and push to Monday.com in one click.",
  "action": {
    "default_title": "ADEQ Toolbar",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "identity",
    "sidePanel"
  ],
  "oauth2": {
    "client_id": "1006462691161-6uicvg6urcco0a50534c46l4jiclfm70.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.send",
      "https://www.googleapis.com/auth/gmail.settings.basic",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://www.google.com https://*.gstatic.com data:; connect-src 'self' https://api.monday.com https://*.rapidapi.com https://generativelanguage.googleapis.com https://api.apollo.io https://www.googleapis.com https://accounts.google.com https://oauth2.googleapis.com https://*.supabase.co https://website.informer.com https://downloads.majesticseo.com https://dns.google https://who.is https://www.similarsites.com;"
  },
  "host_permissions": [
    "https://api.monday.com/*",
    "https://*.rapidapi.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.apollo.io/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://*.supabase.co/*",
    "<all_urls>"
  ]
}
